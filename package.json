{
  "name": "box-dimension-calculator",
  "version": "2.0.0",
  "description": "A production-ready, framework-agnostic TypeScript library for calculating box dimensions with optional React, Vue, and Angular adapters",
  "author": {
    "name": "Shubham Ayodhyavasi, Anas M.I."
  },
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs",
      "types": "./dist/core/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs",
      "types": "./dist/react/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.cjs",
      "types": "./dist/vue/index.d.ts"
    },
    "./angular": {
      "import": "./dist/angular/index.js",
      "require": "./dist/angular/index.cjs",
      "types": "./dist/angular/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@angular/core": "^21.2.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue": "^3.5.30"
  },
  "peerDependencies": {
    "@angular/core": ">=12.0.0",
    "react": ">=17.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    }
  },
  "keywords": [
    "box",
    "dimensions",
    "calculator",
    "shipping",
    "typescript",
    "react",
    "vue",
    "angular"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shubhamAyodhyavasi/box-dimension-calculator.git"
  },
  "bugs": {
    "url": "https://github.com/shubhamAyodhyavasi/box-dimension-calculator/issues"
  },
  "homepage": "https://github.com/shubhamAyodhyavasi/box-dimension-calculator#readme"
}
